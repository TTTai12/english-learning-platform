## 8. CODING STANDARDS

```tsx
// ✅ Mỗi component có Interface Props rõ ràng
interface FlashCardProps {
  word: string;
  meaning: string;
  onKnown: () => void;
  onUnknown: () => void;
}

// ✅ Mọi custom hook bắt đầu bằng use
function useFlashcard(words: Word[]) { ... }

// ✅ Mọi API call có loading + error state
const { data, isLoading, error } = useQuery(...)

// ✅ Tailwind: dùng cn() cho conditional class
className={cn("base-class", isActive && "active-class", className)}

// ✅ Tailwind: mobile-first
className="flex flex-col sm:flex-row lg:gap-8"

// ✅ Comment tiếng Việt cho logic phức tạp
// Tính XP cần thiết để lên level tiếp theo
const xpToNext = level * 500 - currentXP;
```

